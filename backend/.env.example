# Backend environment variables
API_ENV=development
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
AUTH_PROVIDER=dev
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=authenticated

# Data layer (future)
# Default local DB (no setup needed)
DATABASE_URL=sqlite:///./process_automation.db

# Use Postgres in production/staging
# DATABASE_URL=postgresql://user:password@localhost:5432/process_automation
REDIS_URL=redis://localhost:6379/0

# AI provider (future)
OPENAI_API_KEY=your_openai_api_key

# Auth provider (future; if using Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWKS_URL=
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
