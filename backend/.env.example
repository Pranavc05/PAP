# Backend environment variables
API_ENV=development
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
AUTH_PROVIDER=dev
AUTH_JWKS_URL=
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=authenticated
AUTH_JWT_ALGORITHMS=RS256

# Data layer (future)
# Default local DB (no setup needed)
DATABASE_URL=sqlite:///./process_automation.db

# Use Postgres in production/staging
# DATABASE_URL=postgresql://user:password@localhost:5432/process_automation
REDIS_URL=redis://localhost:6379/0

# AI provider
AI_PROVIDER=azure_openai
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=

# OIDC mode examples (AWS/GCP/Azure) - set AUTH_PROVIDER=oidc
# AUTH_JWKS_URL=https://example.com/.well-known/jwks.json
# AUTH_JWT_ISSUER=https://example.com/
# AUTH_JWT_AUDIENCE=api://your-audience
